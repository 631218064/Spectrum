# =============================================
# Spectrum 交友平台环境变量配置示例文件（Supabase + Vercel 版）
# 使用时请复制为 .env 或 .env.local，并根据实际情况修改
# 所有以 NEXT_PUBLIC_ 开头的变量会暴露给浏览器，请勿存放敏感信息
# =============================================

# ---------- Supabase 配置（必需）----------
# 说明：用于数据库、认证、存储
# 获取方式：在 Supabase 项目控制台的 Project Settings > API 中找到
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co    # 你的 Supabase 项目 URL（例如 https://xyzabc.supabase.co）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # 匿名密钥（public），浏览器端使用

# 服务角色密钥（仅在后端 API 路由中使用，切勿暴露给浏览器）
# 获取方式：同上位置，service_role 密钥
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # 具有管理员权限的密钥，用于绕过 RLS

# ---------- 站点基础配置 ----------
# 说明：用于生成绝对链接、回调地址等
NEXT_PUBLIC_SITE_URL=https://your-domain.com      # 生产环境域名（如 https://spectrum.vercel.app）
# 本地开发时可设为 http://localhost:3000，例如：
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth 配置（虽然我们使用 Supabase Auth，但 NextAuth 可能需要某些环境变量）
# 这里 NEXTAUTH_URL 通常与站点 URL 相同
NEXTAUTH_URL=https://your-domain.com               # 生产环境域名（与 NEXT_PUBLIC_SITE_URL 保持一致）
# NEXTAUTH_URL=http://localhost:3000               # 本地开发时使用

# NextAuth 加密密钥（必须设置，用于加密 session）
# 生成方法：在终端执行 `openssl rand -base64 32` 或 `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
NEXTAUTH_SECRET=your_random_secret_here            # 至少 32 字符的随机字符串

# ---------- DeepSeek AI 配置（可选）----------
# 说明：用于生成每日浪漫线索。如不配置或禁用，将使用本地模板回退
DEEPSEEK_API_KEY=sk-your-deepseek-api-key          # DeepSeek API Key（从 DeepSeek 官网获取）
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions  # API 地址（默认即可，一般无需修改）
AI_CLUE_ENABLED=true                               # 是否启用 AI 生成线索（true/false，默认为 false）

# ---------- 定时任务保护密钥（可选）----------
# 说明：用于保护 /api/cron/ 端点，防止未授权调用。如果配置了 Vercel Cron，建议设置
# 在 Vercel 的 Cron 调用时，需在请求头中携带 Authorization: Bearer <此密钥>
CRON_SECRET=your_random_cron_secret_here           # 任意随机字符串，与 vercel.json 中保持一致

# ---------- 其他可选配置 ----------
# 如需要调试，可添加 DEBUG 变量（例如 DEBUG=* 或 DEBUG=pg:*）
# DEBUG=*